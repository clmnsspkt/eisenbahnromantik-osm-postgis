TARGET_DB_HOST=db
TARGET_DB_PORT=5432
POSTGRES_PORT=5432
TARGET_DB_NAME=eisenbahn_demo
TARGET_DB_USER=postgres
TARGET_DB_PASSWORD=postgres

OSM_IMPORT_SCHEMA=osm_import_demo
OSM_IMPORT_SCHEMAS=osm_import_demo
PBF_PATH=/data/example.osm.pbf

OSM2PGSQL_CACHE=1024
OSM2PGSQL_JOBS=4

CHECKPOINT_CLUSTER_RADIUS_M=350
CHECKPOINT_BUFFER_M=500
CHECKPOINT_STOPAREA_SWALLOW_RADIUS_M=350
CHECKPOINT_ALIAS_RADIUS_M=500
CHECKPOINT_STOPAREA_LINK_RADIUS_M=100
CHECKPOINT_NAME_STRIP_PARENS=true
CHECKPOINT_KEEP_TIEF_VARIANTS=true
CHECKPOINT_STOPAREA_DEDUP_GRID_M=1
CHECKPOINT_STRICT_RAIL_ONLY=true
CHECKPOINT_EXCLUDE_TRAM_STOPS=true
